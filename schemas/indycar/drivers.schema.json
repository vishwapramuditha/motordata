{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndyCar Drivers Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "name": {
        "type": "string"
      },
      "number": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "team": {
        "type": "string"
      },
      "engine": {
        "type": "string",
        "enum": ["Honda", "Chevrolet"]
      },
      "nationality": {
        "type": "string"
      }
    },
    "required": ["id", "name", "number", "team", "engine", "nationality"],
    "additionalProperties": false
  }
}
